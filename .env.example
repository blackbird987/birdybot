# Quick setup: python scripts/setup.py
#
# --- Discord (required) ---
# DISCORD_BOT_TOKEN=your-discord-bot-token-here
# DISCORD_GUILD_ID=your-guild-id
# DISCORD_USER_ID=your-discord-user-id
# DISCORD_CATEGORY_NAME=dev - my project
# Auto-creates a private category + lobby channel visible only to you and the bot.
# Or set these manually to skip auto-provisioning:
# DISCORD_LOBBY_CHANNEL_ID=your-lobby-channel-id
# DISCORD_CATEGORY_ID=your-task-category-id

# --- Shared settings ---
CLAUDE_BINARY=claude
MAX_CONCURRENT=5
DAILY_BUDGET_USD=20.0
STALL_TIMEOUT_SECS=60
MAX_PROCESS_LIFETIME_SECS=14400
INSTANCE_RETENTION_DAYS=7
LOG_LEVEL=INFO
DATA_DIR=data
# PC_NAME=desktop  # Optional: overrides hostname for multi-PC setups

# --- Auto-update (for secondary devices) ---
# Pulls code changes from origin and reboots automatically.
# Only enable on non-primary PCs — the main dev PC pushes, others pull.
# AUTO_UPDATE=true
# AUTO_UPDATE_INTERVAL_SECS=300
# AUTO_UPDATE_BRANCH=master  # Optional: auto-detected from remote HEAD

# --- Multi-account failover ---
# Comma-separated list of Claude config dirs. When one account hits its 5h or
# weekly limit, the bot rotates to the next. Each dir must be independently
# logged in (separate browser OAuth flow per dir).
#
# Setup (one-time per extra account):
#   1. Pick a path, e.g. C:/Users/you/.claude-work
#   2. Authenticate it (interactive — see CLAUDE.md → Multi-Account Setup
#      for the per-shell command). Then run /login inside the CLI.
#   3. Add the path below.
#
# Leave unset for single-account mode (uses default ~/.claude, no failover).
# Bot drops invalid entries at startup and logs an ERROR per dropped path.
# CLAUDE_ACCOUNTS=C:/Users/you/.claude,C:/Users/you/.claude-work

# --- Model policy (post-Fable-PPU) ---
# Fable 5 left subscription pricing on 2026-07-08 and is metered ($10/M in,
# $50/M out). Policy: default every new session to Opus (included in the
# subscription), spend Fable pay-per-use tokens ONLY on the highest-leverage
# steps — planning and code review. Uncomment both lines to activate:
# DEFAULT_SESSION_MODEL=opus
# MODEL_ROUTING=plan:fable,review_plan:fable,review_code:fable
#
# DEFAULT_SESSION_MODEL: last-resort --model for any session with no explicit
#   choice (unset = no --model flag, account CLI default). Never overrides a
#   model-limit failover downgrade.
# MODEL_ROUTING: comma-separated origin:model pairs. Keys are workflow-step
#   origins (direct, plan, build, review_plan, apply_revisions, review_code,
#   verify, commit, bg, ...). Malformed/unknown entries are skipped with a
#   warning. Beats EXPLORE_MODEL and DEFAULT_SESSION_MODEL; loses to an
#   explicit per-instance model and to limit-failover downgrades.

# --- Log triage (periodic bot.log scan via `claude -p`) ---
# Posts anomaly findings to a "🔍 Triage" thread inside The Ark.
# High-severity findings ping DISCORD_USER_ID (rate-limited to once per 6h).
# LOG_TRIAGE_ENABLED=true
# LOG_TRIAGE_INTERVAL_SECS=21600   # 6h (default)
# LOG_TRIAGE_MAX_LINES=500         # per-run cap
# LOG_TRIAGE_TIMEOUT_SECS=60
# LOG_TRIAGE_MODEL=claude-haiku-4-5-20251001

# --- Monitor channels (live dashboards in Discord) ---
# Pattern: MONITOR_{NAME}_URL, MONITOR_{NAME}_AUTH, MONITOR_{NAME}_REFRESH
# MONITOR_AIAGENT_URL=https://degenai.dev
# MONITOR_AIAGENT_AUTH=basic:agent:ardi
# MONITOR_AIAGENT_REFRESH=14400
# MONITOR_REFRESH_SECS=14400
